# OSINT API Keys - Get these from their respective platforms

# AlienVault OTX API Key
# Get from: https://otx.alienvault.com/api
OTX_API_KEY=your_otx_api_key_here

# VirusTotal API Key
# Get from: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# MongoDB Configuration (optional if using custom MongoDB instance)
# Default: mongodb://localhost:27017/
MONGODB_URI=mongodb://localhost:27017/

# Elasticsearch Configuration (optional if using custom Elasticsearch instance)
# Default: http://localhost:9200
ELASTICSEARCH_HOST=http://localhost:9200

# Environment
ENVIRONMENT=development
